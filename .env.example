# ===================================================================
# 環境設定ファイルサンプル
# ===================================================================
# このファイルは環境設定のテンプレートです。
# 実際の開発・本番環境では、このファイルをコピーして適切な値を設定してください。
#
# 使用方法:
# 1. このファイルを .env.local または .env.docker にコピー
# 2. 実際の値で置き換え（特にSECRET_KEYとパスワード）
# 3. 機密情報を含むファイルはGitにコミットしない
# ===================================================================

# Django基本設定
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-this-to-a-real-secret-key-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQLデータベース設定
POSTGRES_DB=pokeback_v2
POSTGRES_USER=your-username
POSTGRES_PASSWORD=your-secure-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# データベースURL（オプション - 上記の個別設定の代わりに使用可能）
# DATABASE_URL=postgresql://username:password@host:port/database

# ===================================================================
# セキュリティ注意事項:
# ===================================================================
#
# 🔐 SECRET_KEY:
#   - 本番環境では必ず変更してください
#   - 50文字以上のランダムな文字列を推奨
#   - 生成例: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
# 🔒 パスワード:
#   - 強力なパスワードを使用してください
#   - 他のサービスと同じパスワードを使用しないでください
#
# 🚫 Git管理:
#   - このファイルに実際の機密情報を入力した場合、Gitにコミットしないでください
#   - .gitignoreで .env.* ファイルは除外設定済みです
#
# 🌐 本番環境:
#   - DEBUG=False に設定してください
#   - ALLOWED_HOSTSに本番ドメインを設定してください
#   - 環境変数やシークレット管理サービスの使用を検討してください
# ===================================================================
